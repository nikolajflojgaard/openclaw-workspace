!/SOUL.md
!/TOOLS.md
!/USER.md
!/memory/
!/memory/**
/memory/.dreams/
/memory/.dreams/**
/memory/index.json
/memory/*-state.json
!/prompts/
!/prompts/**
!/scripts/
!/scripts/**
!/skills/
!/skills/**
